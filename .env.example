# NVIDIA NIM API Key (get from https://build.nvidia.com)
NGC_API_KEY=nvapi-your-key-here

# Shopify Store
SHOPIFY_STORE_URL=nakaimatcha.com
SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token
SHOPIFY_ADMIN_TOKEN=shpat_your-admin-token

# Security
REFRESH_SECRET=change-me-to-a-random-string

# CORS (comma-separated allowed origins)
ALLOWED_ORIGINS=https://nakaimatcha.com,https://www.nakaimatcha.com

# NVIDIA Models (defaults — no need to change)
NVIDIA_CHAT_MODEL=nvidia/nemotron-nano-9b-v2
NVIDIA_EMBED_MODEL=baai/bge-m3

# ChromaDB storage path
CHROMA_PERSIST_DIR=./data/chroma_db
