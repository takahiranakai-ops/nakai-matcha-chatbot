<section class="hero-banner">
  <div class="hero-banner__content">
    {%- if section.settings.heading != blank -%}
      <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="hero-banner__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="hero-banner__button">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
  {%- if section.settings.image -%}
    <img
      src="{{ section.settings.image | image_url: width: 1920 }}"
      alt="{{ section.settings.heading | escape }}"
      class="hero-banner__image"
      loading="eager"
    >
  {%- endif -%}
</section>

<style>
  .hero-banner {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(145deg, var(--color-primary, #406546), #2D4A32);
    overflow: hidden;
  }
  .hero-banner__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: .3;
  }
  .hero-banner__content {
    position: relative;
    z-index: 2;
    padding: 4rem 2rem;
    max-width: 700px;
  }
  .hero-banner__heading {
    font-family: var(--font-heading-family);
    font-size: 5rem;
    font-weight: 300;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .hero-banner__subheading {
    font-size: 1.6rem;
    font-weight: 300;
    letter-spacing: .1em;
    color: rgba(255,255,255,.7);
    margin-bottom: 2.5rem;
  }
  .hero-banner__button {
    display: inline-block;
    padding: 1.2rem 3.6rem;
    border: 1px solid rgba(255,255,255,.5);
    border-radius: 9999px;
    color: #fff;
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: .14em;
    text-transform: uppercase;
    transition: all .4s ease;
  }
  .hero-banner__button:hover {
    background: #fff;
    color: var(--color-primary, #406546);
    border-color: #fff;
  }
  @media screen and (max-width: 749px) {
    .hero-banner { min-height: 50vh; }
    .hero-banner__heading { font-size: 3.2rem; letter-spacing: .14em; }
    .hero-banner__subheading { font-size: 1.4rem; }
  }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NAKAI Matcha"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium Japanese Matcha"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
