<section class="main-page page-width">
  <h1 class="main-page__heading">{{ page.title }}</h1>
  <div class="main-page__content rte">
    {{ page.content }}
  </div>
</section>

<style>
  .main-page { padding: 3rem 0; max-width: 800px; margin: 0 auto; }
  .main-page__heading {
    font-family: var(--font-heading-family);
    font-size: 2.8rem;
    font-weight: 400;
    letter-spacing: .08em;
    color: var(--color-primary, #406546);
    margin-bottom: 2rem;
    text-align: center;
  }
  .main-page__content {
    font-size: 1.5rem;
    line-height: 1.8;
    color: var(--color-text, #161614);
  }
  .main-page__content img { border-radius: 12px; margin: 1.5rem 0; }
</style>

{% schema %}
{
  "name": "Page",
  "tag": "section",
  "class": "section-main-page",
  "settings": []
}
{% endschema %}
