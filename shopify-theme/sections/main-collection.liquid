<section class="main-collection page-width">
  <h1 class="main-collection__heading">{{ collection.title }}</h1>
  {%- if collection.description != blank -%}
    <p class="main-collection__description">{{ collection.description }}</p>
  {%- endif -%}

  <div class="main-collection__grid">
    {%- for product in collection.products -%}
      <a href="{{ product.url }}" class="product-card">
        <div class="product-card__image-wrap">
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | image_url: width: 400 }}"
              alt="{{ product.title | escape }}"
              loading="lazy"
            >
          {%- endif -%}
        </div>
        <div class="product-card__info">
          <h3 class="product-card__title">{{ product.title }}</h3>
          <p class="product-card__price">{{ product.price | money }}</p>
        </div>
      </a>
    {%- endfor -%}
  </div>

  {%- if paginate.pages > 1 -%}
    {% render 'pagination', paginate: paginate %}
  {%- endif -%}
</section>

<style>
  .main-collection { padding: 3rem 0; }
  .main-collection__heading {
    font-family: var(--font-heading-family);
    font-size: 2.8rem;
    font-weight: 400;
    letter-spacing: .1em;
    text-transform: uppercase;
    text-align: center;
    color: var(--color-primary, #406546);
    margin-bottom: 1rem;
  }
  .main-collection__description {
    font-size: 1.4rem;
    color: var(--color-text-secondary, #7A766D);
    text-align: center;
    margin-bottom: 3rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .main-collection__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  @media screen and (max-width: 989px) {
    .main-collection__grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-main-collection",
  "settings": []
}
{% endschema %}
