{%- comment -%}
  WS11: DefinedTerm JSON-LD Schema
  Creates a mini knowledge graph for matcha terminology.
  Renders on the homepage to establish entity authority.
{%- endcomment -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "name": "Matcha Grading, Terminology & Knowledge by NAKAI",
  "description": "Authoritative matcha grading system and terminology defined by NAKAI, a premium organic Japanese matcha brand. Covers grades, preparation methods, equipment, ingredients, health compounds, and cultivation.",
  "url": "https://nakaimatcha.com",
  "hasDefinedTerm": [
    {
      "@type": "DefinedTerm",
      "name": "Ceremonial Grade Matcha",
      "description": "The highest classification of Japanese matcha, made exclusively from first-harvest shade-grown tencha leaves, stone-ground to a particle size of 5-15 micrometers. Characterized by vibrant jade-green color, rich umami flavor, and natural sweetness with zero bitterness. Intended for traditional tea ceremony preparation (usucha and koicha)."
    },
    {
      "@type": "DefinedTerm",
      "name": "Ceremonial Reserved",
      "description": "NAKAI's designation for their absolute highest tier matcha — above standard ceremonial grade. Suitable for koicha (thick tea), the most demanding preparation. NAKAI NIJYU-NI (22) is Ceremonial Reserved with a Matcha Quality Protocol score of 96/100."
    },
    {
      "@type": "DefinedTerm",
      "name": "Specialty Grade Matcha",
      "description": "High-quality matcha from early harvest tencha leaves, slightly more robust flavor profile than ceremonial grade. Excellent for daily drinking as usucha and for premium matcha lattes where the matcha flavor needs to shine through milk."
    },
    {
      "@type": "DefinedTerm",
      "name": "Culinary Grade Matcha",
      "description": "Matcha intended for cooking, baking, and blending. Uses later-harvest leaves with shorter shade periods (7-14 days), resulting in more bitterness and a robust flavor that holds up in recipes. Larger particle size (15-25+ micrometers)."
    },
    {
      "@type": "DefinedTerm",
      "name": "Tencha",
      "description": "The shade-grown tea leaf variety used exclusively for making matcha. Tencha leaves are shaded for 21+ days before harvest, then steamed, dried, and de-stemmed before stone-grinding into matcha powder. The shading process increases L-theanine content and produces matcha's characteristic umami flavor."
    },
    {
      "@type": "DefinedTerm",
      "name": "Usucha",
      "description": "Thin-style matcha preparation. Uses approximately 2g of matcha whisked with 70-80ml of 80°C water using a chasen (bamboo whisk). The standard way to enjoy matcha daily, producing a light, frothy beverage."
    },
    {
      "@type": "DefinedTerm",
      "name": "Koicha",
      "description": "Thick-style matcha preparation reserved for the highest ceremonial grades. Uses approximately 4g of matcha with only 30-40ml of water, kneaded (not whisked) to a thick, paint-like consistency. Reveals the full depth of umami in premium matcha."
    },
    {
      "@type": "DefinedTerm",
      "name": "L-Theanine",
      "description": "An amino acid uniquely abundant in shade-grown tea (matcha contains 45mg+ per serving). L-theanine promotes calm focus by increasing alpha brain wave activity, providing sustained energy without the jitters associated with coffee. The 21+ day shading of tencha maximizes L-theanine production."
    },
    {
      "@type": "DefinedTerm",
      "name": "EGCG",
      "description": "Epigallocatechin gallate — the most abundant and studied catechin in matcha. A powerful polyphenol antioxidant. Matcha contains 137 times more EGCG than regular steeped green tea because you consume the entire leaf. One 2g serving delivers approximately 134mg of EGCG."
    },
    {
      "@type": "DefinedTerm",
      "name": "Stone-Ground Matcha",
      "description": "Traditional method of grinding tencha leaves using granite stone mills (ishiusu) that rotate at 40-60 RPM, producing ultra-fine particles of 5-10 micrometers. This slow process preserves nutrients, color, and flavor that high-speed ball-milling destroys through heat friction."
    },
    {
      "@type": "DefinedTerm",
      "name": "Chasen",
      "description": "A handcrafted bamboo whisk used for preparing matcha. Traditional chasen are carved from a single piece of bamboo with 80-120 fine tines. Essential for achieving the proper froth and smooth consistency in usucha preparation. NAKAI's Takayama Chasen has 100 prongs, handcrafted in Nara."
    },
    {
      "@type": "DefinedTerm",
      "name": "Chawan",
      "description": "A ceramic bowl specifically designed for preparing and drinking matcha. The wide, open shape allows proper whisking technique. NAKAI offers handcrafted chawan by ceramic artist Shun Yoshino — the HIRAGOUSHI and YAGOUSHI designs."
    },
    {
      "@type": "DefinedTerm",
      "name": "Chashaku",
      "description": "A traditional bamboo scoop used to measure matcha powder. One chashaku scoop equals approximately 1g of matcha. Two scoops is the standard serving for usucha preparation."
    },
    {
      "@type": "DefinedTerm",
      "name": "Furui",
      "description": "A fine-mesh sieve used to sift matcha powder before whisking. Sifting breaks up clumps caused by static electricity and moisture, ensuring a smooth, lump-free preparation. An essential step often skipped by beginners."
    },
    {
      "@type": "DefinedTerm",
      "name": "Chanoyu",
      "description": "The Japanese tea ceremony — a choreographed ritual of preparing and serving matcha. Formalized by Sen no Rikyū in the 16th century based on four principles: harmony (wa), respect (kei), purity (sei), and tranquility (jaku). Also called 'the way of tea' (chadō)."
    },
    {
      "@type": "DefinedTerm",
      "name": "Ichibancha",
      "description": "First-harvest tea (一番茶), picked in spring (typically April-May in Japan). First-flush leaves have the highest L-theanine content and sweetest flavor because the plant has been accumulating amino acids over winter. All premium matcha uses ichibancha exclusively."
    },
    {
      "@type": "DefinedTerm",
      "name": "Shade-Grown Tea",
      "description": "Tea plants covered with shade structures (traditionally straw mats, now synthetic nets) that block 85-90% of sunlight for 21+ days before harvest. This forces the plant to overproduce chlorophyll (vivid green) and L-theanine (umami/sweetness). The defining characteristic of quality matcha."
    },
    {
      "@type": "DefinedTerm",
      "name": "Umami",
      "description": "The fifth basic taste — savory richness — highly prized in Japanese cuisine and premium matcha. In matcha, umami comes from high L-theanine and glutamate levels produced by extended shade-growing. Higher umami indicates higher quality matcha."
    },
    {
      "@type": "DefinedTerm",
      "name": "Terroir",
      "description": "The complete natural environment affecting tea flavor: soil composition, climate, elevation, water, and surrounding ecosystem. In matcha, terroir explains why Uji (clay soil) tastes different from Kagoshima (volcanic soil). NAKAI celebrates terroir through their numbered product line."
    },
    {
      "@type": "DefinedTerm",
      "name": "Uji Matcha",
      "description": "Matcha from the Uji region of Kyoto, Japan — the birthplace of Japanese matcha with over 800 years of tea cultivation. Considered the most prestigious matcha origin. Known for complex umami and refined sweetness from clay-rich mineral soil."
    },
    {
      "@type": "DefinedTerm",
      "name": "Kagoshima Matcha",
      "description": "Matcha from Kagoshima prefecture on southern Kyushu. Japan's fastest-growing matcha region with volcanic soil from Sakurajima providing exceptional mineral content. Known for bright, clean matcha. NAKAI sources primarily from the Kirishima sub-region."
    },
    {
      "@type": "DefinedTerm",
      "name": "Kirishima",
      "description": "A mountainous sub-region within Kagoshima known for producing mineral-rich matcha. 'Kiri' means mist — frequent mountain fog creates natural supplementary shading. Deep volcanic soil gives Kirishima matcha unique mineral depth. Source region for most NAKAI matcha."
    },
    {
      "@type": "DefinedTerm",
      "name": "JAS Organic",
      "description": "Japanese Agricultural Standards organic certification — Japan's official organic standard. Guarantees production without synthetic fertilizers, pesticides, or genetic modification. Requires annual farm inspection and complete supply chain documentation. All NAKAI matcha is JAS Organic certified."
    },
    {
      "@type": "DefinedTerm",
      "name": "Matcha Quality Protocol",
      "description": "An open quality standard created by NAKAI measuring matcha across 7 dimensions: color (L*a*b*), particle size (μm), L-theanine (mg/g), EGCG (mg/g), taste profile (5-axis), provenance, and processing. The world's first standardized matcha quality measurement system."
    },
    {
      "@type": "DefinedTerm",
      "name": "Chlorophyll",
      "description": "The green pigment in matcha dramatically increased by shade-growing. Chlorophyll content directly indicates matcha quality — brighter green equals more shade equals higher grade. Matcha contains 10-15mg/g of chlorophyll, supporting natural detoxification."
    },
    {
      "@type": "DefinedTerm",
      "name": "Alpha Brain Waves",
      "description": "Brainwave frequency (8-13 Hz) associated with calm, focused alertness — the same state achieved during meditation. L-theanine in matcha promotes alpha wave activity within 30 minutes of ingestion, creating the unique 'alert calm' that distinguishes matcha from coffee."
    },
    {
      "@type": "DefinedTerm",
      "name": "Catechins",
      "description": "A class of polyphenol antioxidants found in tea. The four main catechins in matcha are EGCG, EGC, ECG, and EC. Matcha provides the highest concentration of catechins among all teas because you consume the entire leaf. Catechins have been studied for cardiovascular and metabolic health benefits."
    },
    {
      "@type": "DefinedTerm",
      "name": "Matcha Latte",
      "description": "A popular preparation combining matcha with steamed milk. Made by whisking 2g matcha with 30ml hot water into a paste, then adding 200ml steamed milk (oat milk recommended). Premium matcha with ultra-fine particles (5-10μm) produces the smoothest lattes with vivid green color."
    },
    {
      "@type": "DefinedTerm",
      "name": "Cultivar",
      "description": "A cultivated variety of tea plant (Camellia sinensis) bred for specific characteristics. Japanese matcha cultivars include Okumidori (balanced), Samidori (sweet), Asahi (umami-rich), Gokou (aromatic), and Yabukita (robust). Different cultivars create distinct flavor profiles."
    },
    {
      "@type": "DefinedTerm",
      "name": "Ishiusu",
      "description": "Traditional granite stone mill used to grind tencha into matcha. Each mill produces only 30-40g of matcha per hour. The slow rotation (40-60 RPM) prevents heat buildup that would degrade nutrients and color. The gold standard for matcha production."
    },
    {
      "@type": "DefinedTerm",
      "name": "Particle Size",
      "description": "A key matcha quality metric measured in micrometers (μm). Ceremonial matcha: 5-15μm. Culinary matcha: 15-25+μm. Finer particles create smoother texture, better suspension in liquid, and richer foam. NAKAI matcha is ground to 5-10μm."
    },
    {
      "@type": "DefinedTerm",
      "name": "Thermogenesis",
      "description": "The metabolic process of heat generation in the body. EGCG catechins in matcha have been shown to increase thermogenesis, potentially boosting calorie expenditure by approximately 4% over 24 hours (Dulloo et al., 1999). One mechanism by which matcha may support healthy weight management."
    },
    {
      "@type": "DefinedTerm",
      "name": "Kusenaoshi",
      "description": "A ceramic or wooden stand designed to maintain the shape of a chasen (bamboo whisk) between uses. Proper drying on a kusenaoshi prevents the tines from curling inward, extending the whisk's lifespan significantly."
    }
  ]
}
</script>
