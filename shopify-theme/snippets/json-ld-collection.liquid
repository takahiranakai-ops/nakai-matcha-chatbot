{%- comment -%}
  CollectionPage + ItemList JSON-LD Schema
  Makes every product in a collection visible to AI as a structured catalog.
  AI systems use ItemList to understand product range, pricing, and availability.
  Renders on collection pages via layout/theme.liquid.
{%- endcomment -%}

{%- if collection -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": {{ collection.title | json }},
  "url": "{{ shop.url }}{{ collection.url }}",
  {%- if collection.description != blank -%}
  "description": {{ collection.description | strip_html | truncate: 500 | json }},
  {%- endif -%}
  {%- if collection.image -%}
  "image": "https:{{ collection.image | image_url: width: 1200 }}",
  {%- endif -%}
  "isPartOf": {
    "@type": "WebSite",
    "name": "NAKAI Matcha",
    "url": "https://nakaimatcha.com"
  },
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": {{ collection.products_count }},
    "itemListElement": [
      {%- for product in collection.products limit: 30 -%}
      {
        "@type": "ListItem",
        "position": {{ forloop.index }},
        "item": {
          "@type": "Product",
          "name": {{ product.title | json }},
          "url": "{{ shop.url }}{{ product.url }}",
          {%- if product.featured_image -%}
          "image": "https:{{ product.featured_image | image_url: width: 800 }}",
          {%- endif -%}
          "brand": { "@type": "Brand", "name": "NAKAI" },
          "offers": {
            "@type": "Offer",
            "priceCurrency": "{{ cart.currency.iso_code }}",
            "price": "{{ product.price | money_without_currency | strip_html | strip }}",
            "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
            "seller": { "@type": "Organization", "name": "NAKAI" }
          }
        }
      }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
}
</script>
{%- endif -%}
