{%- comment -%}
  WebSite + SearchAction JSON-LD Schema
  Enables Google Sitelinks Search Box and establishes site entity.
  Also includes SpeakableSpecification for voice AI assistants.
  Renders on all pages via layout/theme.liquid.
{%- endcomment -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "NAKAI Matcha",
  "alternateName": ["NAKAI", "ナカイ抹茶", "NAKAI Organic Matcha"],
  "url": "https://nakaimatcha.com",
  "description": "Premium organic Japanese matcha. Ceremonial, specialty, and everyday grades sourced from Uji and Kagoshima, Japan. USDA Organic and JAS certified. Stone-ground to 5-10 micrometers.",
  "inLanguage": ["en", "ja"],
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://nakaimatcha.com/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  },
  "publisher": {
    "@type": "Organization",
    "name": "NAKAI",
    "url": "https://nakaimatcha.com"
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", ".hero-banner__heading", ".hero-banner__subheading", ".main-product__title", ".main-product__price"]
  }
}
</script>
