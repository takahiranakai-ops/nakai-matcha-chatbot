<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" dir="{{ request.locale.text_direction }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
  <meta name="theme-color" content="#406546">

  <title>
    {%- if page_title -%}{{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    {%- else -%}{{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {% render 'meta-tags' %}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- comment -%} AI Discovery Layer — WS8 {%- endcomment -%}
  <link rel="alternate" type="text/plain" href="https://nakai-matcha-chat.onrender.com/llms.txt" title="LLMs.txt" />
  <link rel="alternate" type="text/plain" href="https://nakai-matcha-chat.onrender.com/llms-full.txt" title="LLMs Full" />
  <link rel="ai-plugin" href="https://nakai-matcha-chat.onrender.com/.well-known/ai-plugin.json" />

  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preconnect" href="https://nakai-matcha-chat.onrender.com" crossorigin>
  <link rel="dns-prefetch" href="https://nakai-matcha-chat.onrender.com">
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  {%- unless settings.heading_font_family contains 'system' -%}
    <link rel="preload" as="font" href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@300;400;450;500;600&display=swap" crossorigin>
  {%- endunless -%}

  <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@300;400;450;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600&display=swap" rel="stylesheet">

  {{ 'base.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}

  {%- comment -%} JSON-LD Structured Data — Global Schemas {%- endcomment -%}
  {% render 'json-ld-organization' %}
  {% render 'json-ld-website' %}
  {% render 'json-ld-breadcrumb' %}
  {% render 'json-ld-site-navigation' %}

  {%- comment -%} JSON-LD — Product Pages {%- endcomment -%}
  {%- if template.name == 'product' -%}
    {% render 'json-ld-product-enhanced' %}
    {% render 'json-ld-product-faq' %}
    {% render 'json-ld-howto' %}
    {% render 'json-ld-video' %}
    {% render 'aria-product' %}
  {%- endif -%}

  {%- comment -%} JSON-LD — Collection Pages {%- endcomment -%}
  {%- if template.name == 'collection' -%}
    {% render 'json-ld-collection' %}
  {%- endif -%}

  {%- comment -%} JSON-LD — Article Pages {%- endcomment -%}
  {%- if template.name == 'article' -%}
    {% render 'json-ld-article' %}
  {%- endif -%}

  {%- comment -%} JSON-LD — Homepage {%- endcomment -%}
  {%- if template == 'index' -%}
    {% render 'json-ld-defined-term' %}
    {% render 'json-ld-homepage-itemlist' %}
    {% render 'json-ld-video' %}
  {%- endif -%}

  <style>
    :root {
      --color-primary: {{ settings.color_primary | default: '#406546' }};
      --color-secondary: {{ settings.color_secondary | default: '#F9F0E2' }};
      --color-background: {{ settings.color_background | default: '#FFFFFF' }};
      --color-text: {{ settings.color_text | default: '#161614' }};
      --color-text-secondary: {{ settings.color_text_secondary | default: '#7A766D' }};
      --font-body-family: 'Work Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --font-heading-family: 'Work Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --font-jp-family: 'Shippori Mincho', serif;
      --header-height: 72px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { font-size: 62.5%; -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }

    body {
      font-family: var(--font-body-family);
      font-size: 1.5rem;
      font-weight: 400;
      line-height: 1.6;
      color: var(--color-text);
      background-color: var(--color-background);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    a { color: inherit; text-decoration: none; }
    img, video { max-width: 100%; height: auto; display: block; }
    button { font-family: inherit; cursor: pointer; }

    .page-width {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    @media screen and (max-width: 749px) {
      :root { --header-height: 60px; }
      .page-width { padding: 0 1.5rem; }
    }
  </style>
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">
  <a class="skip-to-content-link visually-hidden" href="#MainContent">
    {{ 'accessibility.skip_to_content' | t }}
  </a>

  {% sections 'header-group' %}

  <main id="MainContent" class="content-for-layout" role="main">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  {%- comment -%} NAKAI AI Concierge Chat Widget — Floating on all pages {%- endcomment -%}
  {% render 'nakai-chat-widget' %}

  {%- comment -%} WS6: WebMCP — AI Agent Tool Registration {%- endcomment -%}
  {% render 'webmcp-tools' %}

  <script>
    // Detect dark mode
    if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
      document.documentElement.setAttribute('data-scheme', 'dark');
    }
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
      document.documentElement.setAttribute('data-scheme', e.matches ? 'dark' : 'light');
    });
  </script>
</body>
</html>
